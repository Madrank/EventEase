{
  "name": "eventease",
  "version": "1.0.0",
  "description": "EventEase - Organisateur d'événements",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "build": "cd server && npm install && ./node_modules/.bin/prisma generate && ./node_modules/.bin/tsc",
    "start": "cd server && npx prisma db push && node dist/app.js",
    "test": "cd server && npm test",
    "build:client": "cd client && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
